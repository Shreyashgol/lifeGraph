# Vite env (client-exposed vars must be prefixed with VITE_). Copy to `.env`.

# Base URL of the LifeGraph backend API.
VITE_API_URL=http://localhost:8000

# Google OAuth (Google Identity Services, client-side).
# Create an OAuth 2.0 Client (type: Web) and add this app's origin
# (http://localhost:5173) as an Authorized JavaScript origin.
VITE_GOOGLE_CLIENT_ID=

# Optional comma-separated allowlist for single-tenant gating (leave blank to allow any Google account).
VITE_ALLOWED_EMAILS=
