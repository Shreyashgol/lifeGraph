# LifeGraph environment configuration.
# Copy to `.env` and fill in values. `.env` is git-ignored and never committed.

# --- Application ---
APP_NAME=LifeGraph
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- HTTP server ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api
# JSON array of allowed frontend origins (Vite dev server runs on 5173).
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Persistence ---
# Neon Postgres (production). Use the psycopg v3 driver and require SSL.
DATABASE_URL=postgresql+psycopg://<user>:<password>@<neon-host>/<database>?sslmode=require
# Local development / tests can fall back to SQLite:
# DATABASE_URL=sqlite:///./lifegraph.db

# --- AI provider (Groq) ---
# Optional for Phase 1; required once the intelligence layer (Phase 5) is added.
GROQ_API_KEY=
MODEL_NAME=llama-3.3-70b-versatile

# --- Auth ---
# Secret for signing session JWTs. Generate one, e.g. `openssl rand -hex 32`.
# REQUIRED in production (the app refuses to start with the dev default).
JWT_SECRET=dev-insecure-change-me
JWT_EXPIRY_MINUTES=10080
# Google OAuth 2.0 Web client ID (same value as the frontend's VITE_GOOGLE_CLIENT_ID).
# Required to verify Google sign-in. Find it in Google Cloud Console → Credentials.
GOOGLE_CLIENT_ID=
